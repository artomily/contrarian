# ── ContrarianGuard deployment (Arbitrum Sepolia) ───────────────────────────
# Deployer private key. NEVER commit the real value. Fund this address with
# Arbitrum Sepolia ETH first: https://www.alchemy.com/faucets/arbitrum-sepolia
PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY

# RPC endpoint for Arbitrum Sepolia (public default below; swap for an Alchemy URL)
ARBITRUM_SEPOLIA_RPC_URL=https://sepolia-rollup.arbitrum.io/rpc

# Optional: Arbiscan API key for source verification
ARBISCAN_API_KEY=

# Optional: override admin owner / agent attester (default = deployer address)
OWNER=
ATTESTER=
